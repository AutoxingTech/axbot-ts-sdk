{
  "name": "@kingsimba/axbot-sdk",
  "version": "0.1.1",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./msgs": {
      "import": "./dist/msgs.js",
      "types": "./dist/msgs.d.ts"
    },
    "./geojson": {
      "import": "./dist/geojson.js",
      "types": "./dist/geojson.d.ts"
    },
    "./utils": {
      "import": "./dist/utils.js",
      "types": "./dist/utils.d.ts"
    },
    "./proto": {
      "import": "./dist/proto/generated.js",
      "types": "./dist/proto/generated.d.ts"
    },
    "./decoder": {
      "import": "./dist/binaryMessageDecoder.js",
      "types": "./dist/binaryMessageDecoder.d.ts"
    },
    "./robotApi": {
      "import": "./dist/robotApi.js",
      "types": "./dist/robotApi.d.ts"
    },
    "./objectStore": {
      "import": "./dist/objectStore.js",
      "types": "./dist/objectStore.d.ts"
    },
    "./mapInfo": {
      "import": "./dist/mapInfo.js",
      "types": "./dist/mapInfo.d.ts"
    },
    "./pointCloudParser": {
      "import": "./dist/pointCloudParser.js",
      "types": "./dist/pointCloudParser.d.ts"
    },
    "./pbMessages": {
      "import": "./dist/pbMessages.js",
      "types": "./dist/pbMessages.d.ts"
    },
    "./ws": {
      "import": "./dist/ws.js",
      "types": "./dist/ws.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "msgs": [
        "./src/msgs.ts"
      ],
      "geojson": [
        "./src/geojson.ts"
      ],
      "utils": [
        "./src/utils.ts"
      ],
      "proto": [
        "./src/proto/generated.d.ts"
      ],
      "decoder": [
        "./src/binaryMessageDecoder.ts"
      ],
      "robotApi": [
        "./src/robotApi.ts"
      ],
      "objectStore": [
        "./src/objectStore.ts"
      ],
      "mapInfo": [
        "./src/mapInfo.ts"
      ],
      "pointCloudParser": [
        "./src/pointCloudParser.ts"
      ],
      "pbMessages": [
        "./src/pbMessages.ts"
      ],
      "ws": [
        "./src/ws.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/postbuild.mjs",
    "typecheck": "tsc --noEmit",
    "proto": "node scripts/compile-proto.mjs",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "protobufjs": "^7.4.0"
  },
  "devDependencies": {
    "protobufjs-cli": "^1.1.3",
    "typescript": "^5.4.0"
  }
}